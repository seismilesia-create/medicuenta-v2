# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# IA (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Modelo del asistente. Por defecto usa Claude Haiku 4.5 (chat + OCR/visión).
# Para comparar contra otro modelo (requiere reiniciar el dev server):
#   gemini   → Gemini 2.5 Flash
#   deepseek → DeepSeek V4 Flash
# ASSISTANT_MODEL=gemini
