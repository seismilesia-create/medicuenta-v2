# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# IA (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Modelo del asistente. Por defecto usa Claude Haiku 4.5 (chat + OCR/visión).
# Para comparar contra otro modelo (requiere reiniciar el dev server):
#   gemini   → Gemini 2.5 Flash
#   deepseek → DeepSeek V4 Flash
# ASSISTANT_MODEL=gemini

# ── MercadoPago ─────────────────────────────────────────────────────────────
# Cifrado de los tokens de MP en la tabla mp_conexiones (AES-256-GCM).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠ NO regenerar si ya hay médicos conectados: los tokens guardados quedan ilegibles.
ENCRYPTION_KEY=32_bytes_en_base64

# App de MercadoPago (mercadopago.com.ar/developers → Tus integraciones → Checkout Pro).
# El médico ve el NOMBRE de esta app al autorizar → en producción tiene que ser la del negocio.
MP_CLIENT_ID=your_mp_client_id
MP_CLIENT_SECRET=your_mp_client_secret
# Callback del OAuth. Debe estar cargada IDÉNTICA en el panel de la app de MP.
# MP exige HTTPS: localhost no sirve → usar el preview de Vercel o un túnel.
MP_REDIRECT_URI=https://tu-dominio/api/mercadopago/oauth/callback

# URL pública a la que MP avisa los pagos (notification_url del webhook). Sin esto,
# el paciente paga y la receta nunca se entrega.
PUBLIC_BASE_URL=https://tu-dominio

# Orquestador (avisos proactivos por email — Fase 5 v1b)
# Cuenta gratis en resend.com → API key. Con el remitente sandbox
# (onboarding@resend.dev) se puede enviar al email de la propia cuenta sin dominio.
RESEND_API_KEY=your_resend_api_key
# Email donde el dueño recibe el digest del orquestador (si se omite, usa el del
# perfil es_superadmin).
ORQUESTADOR_EMAIL_TO=tu-email@dominio.com
# Remitente (opcional). Para mandar a una casilla que no sea la de la cuenta de
# Resend hay que verificar un dominio y poner acá una dirección de ese dominio.
# ORQUESTADOR_EMAIL_FROM=MediCuenta <avisos@tudominio.com>
# Secreto que protege el cron (Vercel Cron lo manda como Authorization: Bearer).
CRON_SECRET=un_secreto_largo_y_random
